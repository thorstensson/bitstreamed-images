# Environment Variables for Bitstream Demo

# Cloudflare R2 Public URL
# Replace with your actual Cloudflare R2 bucket URL
VITE_BUCKET_URL=https://your-cloudflare-r2-bucket-url.here

# Optional: Development port (default: 5173)
# PORT=3000

# Optional: Enable debug mode
# VITE_DEBUG=true

# Note: All Vite environment variables must be prefixed with VITE_
# to be exposed to the client-side code.
